---
import Blockquote from '@components/mdx/Blockquote.astro';
import CodeBlock from '@components/mdx/CodeBlock.astro';
import H1 from '@components/mdx/heading/H1.astro';
import H2 from '@components/mdx/heading/H2.astro';
import H3 from '@components/mdx/heading/H3.astro';
import H4 from '@components/mdx/heading/H4.astro';
import H5 from '@components/mdx/heading/H5.astro';
import H6 from '@components/mdx/heading/H6.astro';
import Image from '@components/mdx/Image.astro';
import InlineCode from '@components/mdx/InlineCode.astro';
import Italic from '@components/mdx/Italic.astro';
import ListItem from '@components/mdx/list/ListItem.astro';
import OrderedList from '@components/mdx/list/OrderedList.astro';
import UnorderedList from '@components/mdx/list/UnorderedList.astro';
import MDXLink from '@components/mdx/MDXLink.astro';
import Paragraph from '@components/mdx/Paragraph.astro';
import Strong from '@components/mdx/Strong.astro';
import BlogPostLayout from '@layouts/BlogPostLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
    const posts = await getCollection('blog', ({ data }) => {
        return import.meta.env.PROD ? data.status === 'published' : true;
    });
    return posts.map((post) => ({
        params: { id: post.id },
        props: { post }
    }));
}
const { post } = Astro.props;
const { Content } = await render(post);

const components = {
    h1: H1,
    h2: H2,
    h3: H3,
    h4: H4,
    h5: H5,
    h6: H6,
    p: Paragraph,
    a: MDXLink,
    img: Image,
    code: InlineCode,
    pre: CodeBlock,
    blockquote: Blockquote,
    li: ListItem,
    ol: OrderedList,
    ul: UnorderedList,
    strong: Strong,
    em: Italic
};
---

<BlogPostLayout
    title={post.data.title}
    date={post.data.creationDate.toLocaleDateString()}
    description={post.data.description}
    author='Augusto Ezequiel Ringuelet'
    tags={post.data.tags}>
    <Content components={components} />
</BlogPostLayout>
