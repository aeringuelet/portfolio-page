---
import Icon from './Icon.astro';
import IconBadge from './IconBadge.astro';

interface Props {
    class?: string;
    title?: string;
    icon?: string;
    content?: 'center' | 'left';
}

const { title, icon, content, class: className } = Astro.props;
---

<div class={`card dark:shadow-lg shadow-sm ${className}`}>
    <div class={`card-body ${content === 'center' ? 'flex items-center' : ''}`}>
        {
            icon && (
                <IconBadge class='badge-secondary dark:badge-soft dark:badge-accent'>
                    <Icon name={icon} class='text-3xl' />
                </IconBadge>
            )
        }
        <h2 class='card-title dark:text-white'>{title}</h2>
        <slot />
    </div>
</div>
