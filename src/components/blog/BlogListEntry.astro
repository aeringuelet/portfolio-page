---
import Badge from '@components/Badge.astro';
import Icon from '@components/Icon.astro';
import { buildPath, type Collection, formatDate } from '@utils/index';

interface Props {
    post: Collection<'blog'>;
}
const { post } = Astro.props;
---

<a href={buildPath(`/blog/${post.id}`)} class='w-full'>
    <div
        class='card shadow-2xl bg-base-100 border border-transparent group hover:border-primary transition-all duration-200'>
        <div class='card-body p-4 text-left'>
            <div class='flex items-center gap-1'>
                <Icon name='calendar-date-range' />
                <p class='text-xs'>
                    {formatDate(post.data.creationDate)}
                </p>
            </div>
            <h2 class='card-title group-hover:text-primary text-white'>
                {post.data.title}
            </h2>
            <p class='line-clamp-4'>{post.data.description}</p>
            {
                post.data.tags && post.data.tags.length > 0 && (
                    <div class='card-actions'>
                        {post.data.tags.map((tag) => (
                            <Badge class='badge-outline badge-soft badge-primary'>
                                {tag}
                            </Badge>
                        ))}
                    </div>
                )
            }
        </div>
    </div>
</a>
