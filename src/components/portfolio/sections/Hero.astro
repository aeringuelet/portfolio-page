---
import Button from '@components/Button.astro';
import Icon from '@components/Icon.astro';
import { buildPath } from '@utils/navigation';
---

<div class='flex flex-col w-full gap-8 h-screen bg-base-300 mt-12'>
    <div class='avatar avatar-placeholder justify-center'>
        <div class='w-64'>
            <div class='hover-3d'>
                <figure class='max-w-64 rounded-full bg-secondary/80'>
                    <img
                        class='w-8/12 justify-self-center'
                        src={buildPath('/my-avatar.png')}
                        alt='3d avatar'
                    />
                </figure>
                <div></div>
                <div></div>
                <div></div>
                <div></div>
                <div></div>
                <div></div>
                <div></div>
                <div></div>
            </div>
        </div>
    </div>

    <div class='flex text-center justify-center'>
        <div class='flex flex-col items-center max-w-md gap-6'>
            <div class='badge badge-primary badge-soft badge-lg'>
                Fullstack Software Engineer
            </div>
            <h1 class='text-5xl font-bold text-white'>
                Building Digital Experiences
            </h1>
            <p>
                A playful way to say that I am a software engineer and to show
                my resume in a more engaging way.
            </p>
            <Button class='btn-soft btn-secondary' href='#contact' type='link'
                ><Icon name='chat-bubble-oval-text' />Get In Touch
            </Button>
        </div>
    </div>
</div>
