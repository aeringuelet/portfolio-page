---
import Badge from '@components/Badge.astro';
import Card from '@components/Card.astro';
import Section from '@components/Section.astro';

const skills: { title: string; elements: string[] }[] = [
    {
        title: 'Languages',
        elements: ['TypeScript', 'Python', 'Java']
    },
    {
        title: 'Frameworks & Libraries',
        elements: ['ReactJS', 'Astro', 'Node.js', 'FastAPI']
    },
    {
        title: 'Databases',
        elements: ['PostgreSQL', 'MongoDB', 'MySQL']
    },
    {
        title: 'Infrastructure & DevOps',
        elements: ['Docker', 'AWS']
    }
];
---

<Section
    sectionName='skills'
    title='Technical Skills'
    subtitle='Technologies and tools I work with'
    class='bg-base-100'>
    <div class='grid lg:grid-cols-3 grid-cols-1 gap-4'>
        {
            skills.map((skill) => (
                <Card title={skill.title} class='bg-base-300'>
                    <div class='flex flex-wrap gap-2'>
                        {skill.elements.map((element) => (
                            <Badge class='badge-soft badge-accent'>
                                {element}
                            </Badge>
                        ))}
                    </div>
                </Card>
            ))
        }
    </div>
</Section>
