---
interface Props {
    ordered?: boolean;
    class?: string;
}

const { ordered = false, class: className = '' } = Astro.props;
const Tag = ordered ? 'ol' : 'ul';
const listClass = ordered ? 'list-decimal' : 'list-disc';
---

<Tag class={`${listClass} ml-6 mb-4 space-y-2 ${className}`}>
    <slot />
</Tag>
