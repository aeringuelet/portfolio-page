---
interface Props {
    class?: string;
}

const { class: className = '' } = Astro.props;
---

<footer
    class={`footer sm:footer-horizontal footer-center text-base-content p-8 ${className}`}>
    <aside>
        <p class='italic'>
            Made by <span class='bg-primary text-primary-content'>Me</span> with Astro
            and DaisyUI ❤️
        </p>
    </aside>
</footer>
