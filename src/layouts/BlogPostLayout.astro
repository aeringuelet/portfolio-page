---
import Badge from '@components/Badge.astro';
import Button from '@components/Button.astro';
import Icon from '@components/Icon.astro';
import { formatDate } from '@utils/date';
import { buildPath } from '@utils/navigation';
import BaseLayout from './BaseLayout.astro';

interface Props {
    title: string;
    date: string;
    description?: string;
    author?: string;
    tags?: string[];
}
const { title, date, description, tags } = Astro.props;

const formattedDate = formatDate(new Date(date));
---

<BaseLayout pageTitle={title}>
    <div class='flex justify-center mx-64 flex-col lg:max-w-6xl pt-8'>
        <div class='flex flex-col gap-4'>
            <Button href={buildPath('/blog')} class='btn-ghost' type='link'
                >← Back to Blog</Button
            >
            <div class='flex items-center gap-2'>
                <Icon name='calendar-date-range' class='text-lg' />
                <time class='italic text-sm'>{formattedDate}</time>
            </div>
            <h1 class='text-5xl font-bold text-white'>
                {title}
            </h1>
            {description && <p class='text-xl'>{description}</p>}
            {
                tags && (
                    <div class='flex gap-2'>
                        {tags.map((tag) => (
                            <Badge class='badge-soft badge-primary'>
                                {tag}
                            </Badge>
                        ))}
                    </div>
                )
            }
        </div>
        <div class='divider mt-8 mb-0'></div>
        <article>
            <slot />
        </article>
    </div>
</BaseLayout>
